<!-- Style for active wheel card highlighting -->
<style>
	.active-card {
		border-color: currentColor !important;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.02) !important;
		transform: scale(1.05);
	}
	.active-mobile-card {
		border-color: currentColor !important;
		background: #eff6ff !important;
	}
</style>

<!-- Client side interaction logic -->
<script>
	// Handle desktop buttons
	const desktopButtons = document.querySelectorAll('.module-btn');
	const detailTitle = document.getElementById('module-detail-title');
	const detailDesc = document.getElementById('module-detail-desc');
	
	desktopButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			// Clear active classes
			desktopButtons.forEach(b => {
				b.classList.remove('active-card');
				// Reset color classes on sibling buttons
				const textColor = b.getAttribute('data-color');
				b.style.color = '';
			});
			
			// Set active state
			btn.classList.add('active-card');
			const title = btn.getAttribute('data-title');
			const desc = btn.getAttribute('data-desc');
			const colorClass = btn.getAttribute('data-color');
			
			// Highlight with theme color
			if (btn instanceof HTMLElement) {
				btn.style.color = 'currentColor';
			}
			
			if (detailTitle) {
				detailTitle.textContent = title;
				detailTitle.className = 'text-xl font-bold font-display ' + colorClass;
			}
			if (detailDesc) {
				detailDesc.textContent = desc;
			}
		});
	});

	// Handle mobile buttons
	const mobileButtons = document.querySelectorAll('.mobile-module-btn');
	mobileButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			mobileButtons.forEach(b => b.classList.remove('active-mobile-card'));
			btn.classList.add('active-mobile-card');
			
			const title = btn.getAttribute('data-title');
			const desc = btn.getAttribute('data-desc');
			const colorClass = btn.getAttribute('data-color');
			
			if (detailTitle) {
				detailTitle.textContent = title;
				detailTitle.className = 'text-xl font-bold font-display ' + colorClass;
			}
			if (detailDesc) {
				detailDesc.textContent = desc;
			}
		});
	});
</script>