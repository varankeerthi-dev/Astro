---
import Layout from '../../layouts/Layout.astro';
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.perfecterp.com';
---

<Layout title="SME ERP Software - Origin-ERP" description="Affordable, easy-to-use ERP platform for growing trading, service, and engineering businesses.">
	<section class="max-w-4xl mx-auto px-6 py-20 text-center">
		<h1 class="text-4xl md:text-6xl font-bold font-display mb-6 text-slate-900">ERP Software for Growing SMEs</h1>
		<p class="text-slate-500 text-lg md:text-xl max-w-xl mx-auto mb-12 font-sans leading-relaxed">The easy, affordable cloud ERP designed specifically to help mid-sized trading, construction, and engineering businesses scale.</p>
		<a href={appUrl + "/login"} class="inline-block px-8 py-4 rounded-full bg-blue-600 hover:bg-blue-700 font-semibold text-lg hover:scale-102 transition-all no-underline text-white shadow-lg shadow-blue-500/20 font-sans">
			Start Free Trial
		</a>
	</section>
	
	<section class="py-16 px-6 bg-white border-t border-b border-slate-200/80">
		<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl font-bold font-display mb-4 text-slate-900">Simple, Affordable, Scalable</h2>
				<p class="text-slate-500 leading-relaxed mb-6 font-sans">Unlike heavy enterprise software, Origin-ERP sets up in minutes and requires zero dedicated IT managers.</p>
				<ul class="list-none p-0 flex flex-col gap-3 text-slate-700 font-sans">
					<li class="flex items-center gap-2">âœ“ Intuitive interface with minimal learning curve</li>
					<li class="flex items-center gap-2">âœ“ Secure, role-based user access controls</li>
					<li class="flex items-center gap-2">âœ“ Automated tax & GST calculations</li>
					<li class="flex items-center gap-2">âœ“ Integrated client communication templates</li>
				</ul>
			</div>
			<div class="p-8 rounded-2xl bg-slate-50 border border-slate-200/80">
				<h3 class="text-xl font-bold font-display mb-4 text-blue-600">Rapid Onboarding</h3>
				<p class="text-sm text-slate-500 leading-relaxed font-sans">Import your customer lists and material catalogs via CSV spreadsheets. You can start creating quotes and recording inventory transactions within 5 minutes of sign-up.</p>
			</div>
		</div>
	</section>
</Layout>