---
import Layout from '../../layouts/Layout.astro';
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://mep-project-drab.vercel.app';
---

<Layout title="ERP Software for Construction Companies" description="Optimized project tracking, BOQ management, and site material tools for construction contractors.">
	<section class="max-w-4xl mx-auto px-6 py-20 text-center">
		<h1 class="text-4xl md:text-6xl font-bold font-display mb-6 text-slate-900">Construction ERP Software</h1>
		<p class="text-slate-500 text-lg md:text-xl max-w-xl mx-auto mb-12 font-sans leading-relaxed">Streamline site updates, manage client BOQs, track material consumption, and coordinate subcontractors from one dashboard.</p>
		<a href={appUrl + "/login"} class="inline-block px-8 py-4 rounded-full bg-blue-600 hover:bg-blue-700 font-semibold text-lg hover:scale-102 transition-all no-underline text-white shadow-lg shadow-blue-500/20 font-sans">
			Start Free Trial
		</a>
	</section>
	
	<section class="py-16 px-6 bg-white border-t border-b border-slate-200/80">
		<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl font-bold font-display mb-4 text-slate-900">Built for Site Realities</h2>
				<p class="text-slate-500 leading-relaxed mb-6 font-sans">Construction projects are dynamic. Origin-ERP bridges the gap between the office and the field.</p>
				<ul class="list-none p-0 flex flex-col gap-3 text-slate-700 font-sans">
					<li class="flex items-center gap-2">âœ“ Daily site progress logs with photo uploads</li>
					<li class="flex items-center gap-2">âœ“ BOQ milestone tracking & variance analysis</li>
					<li class="flex items-center gap-2">âœ“ Material issues & site consumption records</li>
					<li class="flex items-center gap-2">âœ“ Subcontractor billing & labor attendance</li>
				</ul>
			</div>
			<div class="p-8 rounded-2xl bg-slate-50 border border-slate-200/80">
				<h3 class="text-xl font-bold font-display mb-4 text-blue-600">Track On-Site Costing</h3>
				<p class="text-sm text-slate-500 leading-relaxed font-sans">Prevent cost overruns by tracking actual material issues against estimated project budgets in real time. Site engineers can request materials directly, routing them to purchase managers for approval.</p>
			</div>
		</div>
	</section>
</Layout>