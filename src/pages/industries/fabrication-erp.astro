---
import Layout from '../../layouts/Layout.astro';
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://mep-project-drab.vercel.app';
---

<Layout title="ERP Software for Fabrication Shops" description="Job estimation, material nesting checks, labor tracking, and work order invoicing for fabrication companies.">
	<section class="max-w-4xl mx-auto px-6 py-20 text-center">
		<h1 class="text-4xl md:text-6xl font-bold font-display mb-6 text-slate-900">Fabrication ERP Software</h1>
		<p class="text-slate-500 text-lg md:text-xl max-w-xl mx-auto mb-12 font-sans leading-relaxed">Perfect job estimation, track raw metal inventories, log assembly labor hours, and generate GST-compliant invoices.</p>
		<a href={appUrl + "/login"} class="inline-block px-8 py-4 rounded-full bg-blue-600 hover:bg-blue-700 font-semibold text-lg hover:scale-102 transition-all no-underline text-white shadow-lg shadow-blue-500/20 font-sans">
			Start Free Trial
		</a>
	</section>
	
	<section class="py-16 px-6 bg-white border-t border-b border-slate-200/80">
		<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
			<div>
				<h2 class="text-3xl font-bold font-display mb-4 text-slate-900">Perfect Job Estimations</h2>
				<p class="text-slate-500 leading-relaxed mb-6 font-sans font-sans">Fabrication relies on tight margins and material waste reduction. Track weight, dimensions, and scrap metal details.</p>
				<ul class="list-none p-0 flex flex-col gap-3 text-slate-700 font-sans">
					<li class="flex items-center gap-2">âœ“ Track metal dimensions, thickness & weight</li>
					<li class="flex items-center gap-2">âœ“ Log customized subcontractor work order rates</li>
					<li class="flex items-center gap-2">âœ“ Real-time scrap metal inventory tracking</li>
					<li class="flex items-center gap-2">âœ“ Labor timesheet logging</li>
				</ul>
			</div>
			<div class="p-8 rounded-2xl bg-slate-50 border border-slate-200/80">
				<h3 class="text-xl font-bold font-display mb-4 text-blue-600">Precision Invoicing</h3>
				<p class="text-sm text-slate-500 leading-relaxed font-sans font-sans">Bill clients accurately based on drawing sizes or actual raw materials used. Link custom shipping/delivery challans (DCs) directly to sales invoices to simplify billing.</p>
			</div>
		</div>
	</section>
</Layout>