---
import Layout from '../layouts/Layout.astro';
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://mep-project-drab.vercel.app';
---

<Layout title="Pricing - Simple & Transparent Plans" description="Choose the perfect Origin-ERP plan for your construction, fabrication, or manufacturing business. Start with a free 14-day trial.">
	<section class="max-w-6xl mx-auto px-6 py-20 text-center">
		<h1 class="text-4xl md:text-6xl font-bold font-display tracking-tight mb-4 text-slate-900">Simple, Transparent Pricing</h1>
		<p class="text-slate-500 text-lg md:text-xl max-w-xl mx-auto mb-16 font-sans">All plans include a 14-day free trial. Choose a plan tailored to your business scale.</p>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
			<!-- Starter -->
			<div class="p-8 rounded-2xl bg-white border border-slate-200/80 shadow-xs flex flex-col justify-between">
				<div>
					<h3 class="text-base font-semibold text-blue-600 uppercase tracking-wider mb-2">Starter</h3>
					<div class="text-4xl font-bold text-slate-900 mb-4 font-display"><span class="text-sm font-medium text-slate-400">/month</span></div>
					<p class="text-slate-500 text-sm mb-6 font-sans">Perfect for small teams and contracting startups looking to organize their client quotes and work.</p>
					<ul class="list-none p-0 flex flex-col gap-3 text-sm text-slate-600 border-t border-slate-100 pt-6 mb-8 font-sans">
						<li class="flex items-center gap-2">âœ“ Up to 5 Active Projects</li>
						<li class="flex items-center gap-2">âœ“ Smart Quotation Builder</li>
						<li class="flex items-center gap-2">âœ“ Basic Inventory Management</li>
						<li class="flex items-center gap-2">âœ“ Email Support</li>
					</ul>
				</div>
				<a href={appUrl + "/login"} class="block w-full py-3 text-center rounded-full bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 font-semibold no-underline transition-all font-sans">
					Start Free Trial
				</a>
			</div>
			
			<!-- Growth -->
			<div class="p-8 rounded-2xl bg-white border-2 border-blue-600 relative flex flex-col justify-between shadow-xl shadow-blue-500/5">
				<div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-blue-600 text-white font-bold text-xs uppercase tracking-wide">Most Popular</div>
				<div>
					<h3 class="text-base font-semibold text-blue-600 uppercase tracking-wider mb-2">Growth</h3>
					<div class="text-4xl font-bold text-slate-900 mb-4 font-display"><span class="text-sm font-medium text-slate-400 font-sans">/month</span></div>
					<p class="text-slate-500 text-sm mb-6 font-sans">Built for growing SMEs with multiple warehouses, subcontractors, and more project volumes.</p>
					<ul class="list-none p-0 flex flex-col gap-3 text-sm text-slate-600 border-t border-slate-100 pt-6 mb-8 font-sans">
						<li class="flex items-center gap-2">âœ“ Up to 25 Active Projects</li>
						<li class="flex items-center gap-2">âœ“ Smart Quotation & CRM Hub</li>
						<li class="flex items-center gap-2">âœ“ Multi-Warehouse Stock Tracking</li>
						<li class="flex items-center gap-2">âœ“ Subcontractor & Attendance System</li>
						<li class="flex items-center gap-2">âœ“ Priority Email & Chat Support</li>
					</ul>
				</div>
				<a href={appUrl + "/login"} class="block w-full py-3 text-center rounded-full bg-blue-600 hover:bg-blue-700 text-white font-semibold no-underline hover:scale-102 transition-all font-sans">
					Start Free Trial
				</a>
			</div>
			
			<!-- Scale -->
			<div class="p-8 rounded-2xl bg-white border border-slate-200/80 shadow-xs flex flex-col justify-between">
				<div>
					<h3 class="text-base font-semibold text-blue-600 uppercase tracking-wider mb-2">Enterprise</h3>
					<div class="text-4xl font-bold text-slate-900 mb-4 font-display">Custom</div>
					<p class="text-slate-500 text-sm mb-6 font-sans">Designed for larger mid-sized operations requiring customized templates, dedicated hosting, or API access.</p>
					<ul class="list-none p-0 flex flex-col gap-3 text-sm text-slate-600 border-t border-slate-100 pt-6 mb-8 font-sans">
						<li class="flex items-center gap-2">âœ“ Unlimited Projects & Stock</li>
						<li class="flex items-center gap-2">âœ“ Everything in Growth</li>
						<li class="flex items-center gap-2">âœ“ Custom Invoice & Quote Layouts</li>
						<li class="flex items-center gap-2">âœ“ Dedicated Support Manager</li>
						<li class="flex items-center gap-2">âœ“ 99.9% SLA Guarantee</li>
