---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('help');
---

<Layout title="Help Center - Documentation & Guides" description="Find step-by-step guides, user documentation, and FAQs for Origin-ERP. Learn how to manage projects, create quotes, and track inventory.">
	<section class="max-w-4xl mx-auto px-6 py-20">
		<div class="text-center mb-16">
			<h1 class="text-4xl md:text-6xl font-bold font-display tracking-tight mb-4 text-slate-900">How can we help you?</h1>
			<p class="text-slate-500 text-lg max-w-md mx-auto font-sans">Browse our documentation or search help articles to get started with Origin-ERP.</p>
		</div>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
			<div class="p-6 rounded-2xl bg-white border border-slate-200/80 shadow-xs">
				<h3 class="text-lg font-bold font-display mb-2 text-blue-600">Getting Started</h3>
				<p class="text-sm text-slate-500 mb-4 font-sans">Learn the basics of setting up your organization and configuring workflows.</p>
				<a href="/help/create-quotation" class="text-sm font-semibold text-slate-800 hover:text-blue-600 transition-all no-underline font-sans">Read guide â†’</a>
			</div>
			<div class="p-6 rounded-2xl bg-white border border-slate-200/80 shadow-xs">
				<h3 class="text-lg font-bold font-display mb-2 text-blue-600">Inventory & Operations</h3>
				<p class="text-sm text-slate-500 mb-4 font-sans">Guides on managing stock, site consumption, and warehouse transfers.</p>
				<a href="/help/inventory-transfer" class="text-sm font-semibold text-slate-800 hover:text-blue-600 transition-all no-underline font-sans">Read guide â†’</a>
			</div>
		</div>

		<h2 class="text-2xl font-bold font-display text-slate-900 mb-6">All Articles</h2>
		<div class="flex flex-col gap-4">
			{articles.map(article => (
				<a href={"/help/" + article.id} class="block p-5 rounded-xl bg-white hover:bg-slate-50 border border-slate-200/80 shadow-xs transition-all no-underline group">
					<div class="flex justify-between items-center">
						<div>
							<span class="text-xs text-blue-600 uppercase tracking-wider font-semibold font-sans">{article.data.category}</span>
							<h3 class="text-lg font-bold font-display text-slate-900 mt-1 group-hover:text-blue-600 transition-colors">{article.data.title}</h3>
							<p class="text-sm text-slate-500 mt-1 mb-0 font-sans">{article.data.description}</p>
						</div>
						<span class="text-slate-400 group-hover:text-slate-900 transition-colors font-sans">â†’</span>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>